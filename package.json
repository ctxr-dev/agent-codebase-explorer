{
  "name": "@ctxr/agent-codebase-explorer",
  "version": "1.0.2",
  "description": "Read-only codebase search subagent. Given a brief, it locates files, symbols, and patterns and reports where-is-X / what-references-Y with exact references and a capped, structured report. Read-only; uses whatever capabilities the environment provides and never halts when one is missing or unhealthy.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctxr-dev/agent-codebase-explorer.git"
  },
  "homepage": "https://github.com/ctxr-dev/agent-codebase-explorer#readme",
  "bugs": {
    "url": "https://github.com/ctxr-dev/agent-codebase-explorer/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "package.json",
    "AGENT.md",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "ctxr": {
    "type": "agent",
    "target": "folder"
  },
  "keywords": [
    "agent-skills",
    "agents-md",
    "codex",
    "claude-code",
    "ctxr",
    "agent",
    "ai"
  ],
  "scripts": {
    "validate": "npx @ctxr/kit@latest validate",
    "lint": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "markdownlint-cli2": "^0.14.0"
  }
}
